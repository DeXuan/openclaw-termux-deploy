#!/usr/bin/env bash
#==============================================================================
# OpenClaw Deploy — Termux Fleet Management Toolbox
# 用法: ./openclaw-deploy           交互式 TUI
#       ./openclaw-deploy dashboard 机队仪表盘
#       ./openclaw-deploy wizard    新手向导
#       ./openclaw-deploy check     全队体检
#==============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"
source "$SCRIPT_DIR/lib/menus.sh"
VERSION="1.0.0"

# ═══ Guard ═══
require_openclaw() {
  if ! command -v openclaw &>/dev/null; then
    echo
    log_fail "未检测到 openclaw 命令"
    echo -e "  ${C_DIM}请先完成部署（主菜单选「新手向导」或「部署设备」）${C_RESET}"
    echo -e "  ${C_DIM}或确认 PATH 包含 ~/.npm-global/bin${C_RESET}"
    return 1
  fi
  return 0
}

# ═══ CLI Mode ═══
if [ $# -gt 0 ]; then
  case "$1" in
    wizard|w) wizard_menu; exit 0 ;;
    dashboard|dash|d) dashboard_menu; exit 0 ;;
    check|c)
      local ck="$SCRIPT_DIR/scripts/phone_check_env.sh"
      [ ! -f "$ck" ] && ck="$SCRIPT_DIR/skill/scripts/phone_check_env.sh"
      for dev in K60 Note7; do
        echo -e "\n${C_BOLD}─── $dev ───${C_RESET}"
        ssh_device "$dev" "sh -" < "$ck" 2>&1 || echo "  不可达"
      done
      exit 0
      ;;
    install|i)
      target="${2:-}"; [ -z "$target" ] && { echo "用法: $0 install <K60|Note7|IP> [user]"; exit 1; }
      user="${3:-u0_a129}"
      local inst="$SCRIPT_DIR/scripts/phone_install_openclaw.sh"
      [ ! -f "$inst" ] && inst="$SCRIPT_DIR/skill/scripts/phone_install_openclaw.sh"
      cat "$inst" | ssh -p 8022 "$user@$target" 'sh -'
      exit 0
      ;;
    version|--version|-v)
      echo "openclaw-deploy v$VERSION"
      exit 0
      ;;
    help|--help|-h)
      echo "openclaw-deploy v$VERSION — OpenClaw Termux 机队管理工具箱"
      echo "用法: ./openclaw-deploy              交互式 TUI"
      echo "      ./openclaw-deploy dashboard    机队仪表盘"
      echo "      ./openclaw-deploy wizard       新手部署向导"
      echo "      ./openclaw-deploy check        全队一键体检"
      echo "      ./openclaw-deploy install <t>  远程部署"
      exit 0
      ;;
    *) echo "未知命令: $1"; echo "用法: $0 [dashboard|wizard|check|install|version|help]"; exit 1 ;;
  esac
fi

# ═══ Main ═══
show_menu
