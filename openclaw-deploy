#!/usr/bin/env bash
#==============================================================================
# OpenClaw Deploy — Termux Fleet Management Toolbox
# 用法: ./openclaw-deploy           交互式 TUI
#       ./openclaw-deploy dashboard 机队仪表盘
#       ./openclaw-deploy wizard    新手向导
#       ./openclaw-deploy check     全队体检
#==============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"
VERSION="1.0.0"

# ═══ Guard: openclaw command ═══
require_openclaw() {
  if ! command -v openclaw &>/dev/null; then
    echo
    log_fail "未检测到 openclaw 命令"
    echo -e "  ${C_DIM}请先完成部署（主菜单选「新手向导」或「部署设备」）${C_RESET}"
    echo -e "  ${C_DIM}或确认 PATH 包含 ~/.npm-global/bin${C_RESET}"
    return 1
  fi
  return 0
}

# ═══ Main Menu ═══
show_menu() {
  header
  fleet_status_bar
  echo
  echo -e "  ${C_BOLD}${C_WHITE}主 菜 单${C_RESET}"
  echo

  menu_item "1" "🚀" "新手向导"        "一步步引导完成首次部署"
  menu_item "2" "📦" "部署设备"        "安装 Node.js / OpenClaw / runit"
  menu_item "3" "🔍" "设备体检"        "一键诊断机型/版本/服务状态"
  menu_item "4" "📊" "机队仪表盘"      "四台设备状态实时一览"
  echo
  menu_item "5" "⚙️"  "服务管理"        "启停/重启/日志查看"
  menu_item "6" "🩺" "自愈系统"        "安装/配置/状态/日志"
  menu_item "7" "🧩" "技能工具箱"      "安装/搜索/同步技能"
  menu_item "8" "🤖" "模型与渠道"      "模型管理/渠道状态/额度"
  echo
  menu_item "u" "🔄" "系统更新"        "升级 OpenClaw / Node.js"
  menu_item "h" "📖" "帮助与速查"      "运维命令/文档链接"
  echo
  menu_item "0" "👋" "退出"            ""
  echo
  echo -e "  ${C_DIM}${BOX_H}$(printf "${BOX_H}%.0s" $(seq 1 58))${C_RESET}"
  read -r -p "$(echo -e "  ${C_BOLD}请选择${C_RESET} ${C_DIM}[0-8/u/h]${C_RESET}: ")" choice

  case "$choice" in
    1) wizard_menu ;;
    2) deploy_menu ;;
    3) check_menu ;;
    4) dashboard_menu ;;
    5) service_menu ;;
    6) selfheal_menu ;;
    7) require_openclaw && skills_menu || { press_enter; show_menu; } ;;
    8) require_openclaw && models_menu  || { press_enter; show_menu; } ;;
    u|U) update_menu ;;
    h|H) help_menu ;;
    0) echo -e "\n  ${C_DIM}再见 👋${C_RESET}\n"; exit 0 ;;
    *) show_menu ;;
  esac
}

# ═══ 1. Wizard Mode ═══
wizard_menu() {
  clear
  echo -e "${C_CYAN}${C_BOLD}"
  echo "  ╭──────────────────────────────────────────────╮"
  echo "  │        🚀  新 手 部 署 向 导                 │"
  echo "  ╰──────────────────────────────────────────────╯"
  echo -e "${C_RESET}"
  echo
  echo -e "  ${C_DIM}这个向导将一步步帮你完成 OpenClaw 部署。${C_RESET}"
  echo -e "  ${C_DIM}全程大约 5-10 分钟，大部分步骤自动完成。${C_RESET}"
  echo

  local total=6
  show_step 1 "$total" "检查环境 (Termux/Node.js/Git)"
  show_step 2 "$total" "配置 SSH 免密登录"
  show_step 3 "$total" "安装 OpenClaw + 依赖"
  show_step 4 "$total" "配置模型供应商 (API Key)"
  show_step 5 "$total" "设置 runit 进程保活"
  show_step 6 "$total" "开机自启 + 验证"

  echo
  echo -e "  ${C_DIM}${BOX_H}$(printf "${BOX_H}%.0s" $(seq 1 50))${C_RESET}"
  echo
  echo -e "  ${C_BOLD}选择部署方式:${C_RESET}"
  echo -e "  ${C_BOLD}[1]${C_RESET} ${ICO_PHONE} 本机安装 ${C_DIM}(当前 Termux 手机)${C_RESET}"
  echo -e "  ${C_BOLD}[2]${C_RESET} ${ICO_NET} 远程部署 ${C_DIM}(PC SSH 到手机)${C_RESET}"
  echo -e "  ${C_BOLD}[0]${C_RESET} 返回"
  echo
  read -r -p "$(echo -e "  ${C_BOLD}>${C_RESET} ")" wiz_choice

  case "$wiz_choice" in
    1) run_wizard_local ;;
    2) run_wizard_remote ;;
    *) show_menu; return ;;
  esac
}

run_wizard_local() {
  clear
  echo -e "${C_CYAN}${C_BOLD}  🚀 本机部署向导${C_RESET}\n"

  # Step 1: Environment check
  show_step 1 6 "检查环境…"
  if is_termux; then
    log_ok "Termux 环境 ✓"
    log_info "架构: $(get_arch)"
    if command -v node &>/dev/null; then
      log_ok "Node.js $(node --version) ✓"
    else
      log_warn "Node.js 未安装，将在后续步骤安装"
    fi
  else
    log_fail "未检测到 Termux 环境。请在 Termux App 内运行本向导。"
    log_info "或者使用「远程部署」模式，从 PC 通过 SSH 部署。"
    press_enter; show_menu; return
  fi

  # Step 2: SSH setup
  echo; show_step 2 6 "配置 SSH…"
  if [ -f ~/.ssh/id_ed25519.pub ]; then
    log_ok "SSH 密钥已存在"
  else
    log_step "生成 SSH 密钥对…"
    ssh-keygen -t ed25519 -N "" -f ~/.ssh/id_ed25519 -q && log_ok "已生成" || log_warn "跳过"
  fi

  # Step 3: Install OpenClaw
  echo; show_step 3 6 "安装 OpenClaw…"
  if command -v openclaw &>/dev/null; then
    log_ok "OpenClaw $(openclaw --version 2>/dev/null | head -1) 已安装"
  else
    if [ -f "$SCRIPT_DIR/scripts/phone_install_openclaw.sh" ]; then
      log_step "正在安装 (可能需要几分钟)…"
      spinner_start "安装 OpenClaw..."
      bash "$SCRIPT_DIR/scripts/phone_install_openclaw.sh" 2>&1 | tail -3
      spinner_stop
      command -v openclaw &>/dev/null && log_ok "安装成功" || log_fail "安装失败，请查看上方日志"
    else
      log_fail "找不到安装脚本"
      press_enter; show_menu; return
    fi
  fi

  # Step 4: Configure model
  echo; show_step 4 6 "配置模型…"
  if [ -f ~/.openclaw/openclaw.json ]; then
    log_ok "配置文件已存在"
    log_info "如需更换模型: openclaw onboard --reconfigure"
  else
    echo
    echo -e "  ${C_BOLD}选择模型供应商:${C_RESET}"
    echo -e "  [1] DeepSeek (推荐，有免费额度)"
    echo -e "  [2] 阿里百炼 (需 OAuth 认证)"
    echo -e "  [3] 自定义 API"
    read -r -p "$(echo -e "  ${C_BOLD}>${C_RESET} ")" model_choice
    case "$model_choice" in
      1) openclaw onboard --non-interactive --mode local --auth-choice deepseek-api-key --accept-risk 2>&1 | tail -3 ;;
      2) log_info "请手动运行: openclaw onboard --non-interactive --mode local --auth-choice alibaba-oauth --accept-risk" ;;
      3) log_info "请手动运行: openclaw onboard" ;;
    esac
  fi

  # Step 5: runit service
  echo; show_step 5 6 "设置进程保活…"
  if [ -f "$SCRIPT_DIR/scripts/phone_setup_service.sh" ] || [ -f "$SCRIPT_DIR/skill/scripts/phone_setup_service.sh" ]; then
    local svc_script="$SCRIPT_DIR/scripts/phone_setup_service.sh"
    [ ! -f "$svc_script" ] && svc_script="$SCRIPT_DIR/skill/scripts/phone_setup_service.sh"
    spinner_start "配置 runit 服务..."
    bash "$svc_script" 2>&1 | tail -3
    spinner_stop
    log_ok "runit 服务已配置"
  else
    log_warn "找不到 service 脚本，跳过"
  fi

  # Step 6: Verify
  echo; show_step 6 6 "最终验证…"
  sleep 2
  local http_code
  http_code=$(check_gateway)
  if [ "$http_code" = "200" ]; then
    log_ok "Gateway HTTP 200 — 部署成功！🎉"
    echo
    echo -e "  ${C_GREEN}${C_BOLD}  ✨ OpenClaw 已就绪！${C_RESET}"
    echo -e "  ${C_DIM}  Web 控制台: http://127.0.0.1:18789/${C_RESET}"
    echo -e "  ${C_DIM}  下一步: 安装自愈系统 + 配置聊天渠道${C_RESET}"
  else
    log_warn "Gateway 响应: $http_code (可能正在启动，请等待 15-30 秒)"
  fi

  press_enter; show_menu
}

run_wizard_remote() {
  clear
  echo -e "${C_CYAN}${C_BOLD}  🚀 远程部署向导${C_RESET}\n"

  read -r -p "$(echo -e "  ${C_BOLD}目标设备 IP 或名称${C_RESET} ${C_DIM}(K60/Note7/MIX2S/Note4X 或 IP)${C_RESET}: ")" target
  [ -z "$target" ] && { show_menu; return; }

  # Resolve device name to connection info
  local conn_user="u0_a129" conn_host="$target" conn_port="8022"
  case "$target" in
    K60|Note7|MIX2S|Note4X)
      local conn="${DEVICES[$target]}"
      conn_host="${conn%:*}"
      conn_host="${conn_host#*@}"  # extract host from user@host
      conn_user="${conn%@*}"       # extract user from user@host
      conn_port="${conn##*:}"
      ;;
  esac

  show_step 1 3 "SSH 连接测试…"
  if ssh -p "$conn_port" -o ConnectTimeout=5 -o BatchMode=yes "$conn_user@$conn_host" 'echo OK' 2>/dev/null | grep -q OK; then
    log_ok "SSH 连接成功"
  else
    log_fail "SSH 无法连接到 $conn_host:$conn_port"
    echo -e "  ${C_DIM}请先在手机上: pkg install openssh && sshd${C_RESET}"
    echo -e "  ${C_DIM}然后配置免密: ssh-copy-id -p $conn_port $conn_user@$conn_host${C_RESET}"
    press_enter; show_menu; return
  fi

  show_step 2 3 "远程安装 OpenClaw…"
  local inst_script="$SCRIPT_DIR/scripts/phone_install_openclaw.sh"
  [ ! -f "$inst_script" ] && inst_script="$SCRIPT_DIR/skill/scripts/phone_install_openclaw.sh"
  spinner_start "部署到 $target..."
  cat "$inst_script" | ssh -p "$conn_port" "$conn_user@$conn_host" 'sh -' 2>&1 | tail -5
  spinner_stop
  log_ok "部署完成"

  show_step 3 3 "验证…"
  local http_code
  http_code=$(ssh -p "$conn_port" "$conn_user@$conn_host" 'curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 http://127.0.0.1:18789/' 2>/dev/null || echo "fail")
  if [ "$http_code" = "200" ]; then
    log_ok "Gateway HTTP 200 — 部署成功！🎉"
  else
    log_warn "Gateway 响应: $http_code (等待 runit 拉起中…)"
  fi

  press_enter; show_menu
}

# ═══ 2. Deploy ═══
deploy_menu() {
  clear
  header
  echo -e "  ${C_BOLD}${C_WHITE}📦 部署设备${C_RESET}\n"
  echo -e "  ${C_BOLD}[a]${C_RESET} PC 远程部署 ${C_DIM}— SSH 管道安装到目标手机${C_RESET}"
  echo -e "  ${C_BOLD}[b]${C_RESET} 本机安装     ${C_DIM}— 在当前 Termux 直接安装${C_RESET}"
  echo -e "  ${C_BOLD}[0]${C_RESET} 返回"
  echo
  read -r -p "$(echo -e "  ${C_BOLD}>${C_RESET} ")" choice

  case "$choice" in
    a|A)
      read -r -p "  ${C_BOLD}设备${C_RESET} ${C_DIM}(K60/Note7/MIX2S/Note4X 或 IP)${C_RESET}: " target
      [ -z "$target" ] && { show_menu; return; }
      read -r -p "  ${C_BOLD}用户${C_RESET} ${C_DIM}[u0_a129]${C_RESET}: " ssh_user
      ssh_user="${ssh_user:-u0_a129}"
      log_step "远程部署 → $target"
      local inst="$SCRIPT_DIR/scripts/phone_install_openclaw.sh"
      [ ! -f "$inst" ] && inst="$SCRIPT_DIR/skill/scripts/phone_install_openclaw.sh"
      spinner_start "安装中..."
      cat "$inst" | ssh -p 8022 "$ssh_user@$target" 'sh -' 2>&1 | tail -5
      spinner_stop
      log_ok "部署完成"
      ;;
    b|B)
      local inst="$SCRIPT_DIR/scripts/phone_install_openclaw.sh"
      [ ! -f "$inst" ] && inst="$SCRIPT_DIR/skill/scripts/phone_install_openclaw.sh"
      spinner_start "本机安装..."
      bash "$inst" 2>&1 | tail -5
      spinner_stop
      log_ok "安装完成"
      ;;
  esac
  press_enter; show_menu
}

# ═══ 3. Check ═══
check_menu() {
  clear
  header
  echo -e "  ${C_BOLD}${C_WHITE}🔍 设备体检${C_RESET}\n"
  menu_item "1" "📱" "本机体检"        "当前设备一键诊断"
  menu_item "2" "🔥" "K60 远程体检"    "SSH 到 K60 诊断"
  menu_item "3" "🍃" "Note 7 远程体检" "SSH 到 Note 7 诊断"
  menu_item "4" "📊" "全队体检"        "两台在线设备一键体检"
  echo -e "  ${C_BOLD}[0]${C_RESET} 返回"
  echo
  read -r -p "$(echo -e "  ${C_BOLD}>${C_RESET} ")" choice

  local ck="$SCRIPT_DIR/scripts/phone_check_env.sh"
  [ ! -f "$ck" ] && ck="$SCRIPT_DIR/skill/scripts/phone_check_env.sh"

  case "$choice" in
    1) [ -f "$ck" ] && bash "$ck" || log_fail "找不到体检脚本" ;;
    2) spinner_start "连接 K60..."; ssh_device K60 "sh -" < "$ck" 2>&1; spinner_stop ;;
    3) spinner_start "连接 Note 7..."; ssh_device Note7 "sh -" < "$ck" 2>&1; spinner_stop ;;
    4)
      for dev in K60 Note7; do
        echo -e "\n  ${C_BOLD}── ${dev} ──${C_RESET}"
        spinner_start "检查 $dev..."
        ssh_device "$dev" "sh -" < "$ck" 2>&1 || echo "  ${ICO_FAIL} 不可达"
        spinner_stop
      done
      ;;
  esac
  press_enter; show_menu
}

# ═══ 4. Dashboard ═══
dashboard_menu() {
  clear
  header
  echo -e "  ${C_BOLD}${C_WHITE}📊 机队仪表盘${C_RESET}     ${C_DIM}$(date '+%Y-%m-%d %H:%M')${C_RESET}"
  echo
  echo -e "  ${C_DIM}${BOX_TL}$(printf "${BOX_H}%.0s" $(seq 1 56))${BOX_TR}${C_RESET}"

  local k60_gw n7_gw k60_mem n7_mem k60_disk n7_disk k60_swap n7_swap k60_up n7_up

  # K60
  k60_gw=$(ssh_device K60 'curl -s -o /dev/null -w "%{http_code}" --connect-timeout 3 http://127.0.0.1:18789/' 2>/dev/null) || k60_gw="fail"
  k60_mem=$(ssh_device K60 'free -h | awk "/^Mem:/ {print \$7}"' 2>/dev/null) || k60_mem="—"
  k60_disk=$(ssh_device K60 'df -h /data/data/com.termux/files 2>/dev/null|awk "NR==2{print \$3\"/\"\$2\" \"\$5}"' 2>/dev/null) || k60_disk="—"
  [ -z "$k60_disk" ] && k60_disk=$(ssh_device K60 'df -h /data 2>/dev/null|awk "NR==2{print \$3\"/\"\$2\" \"\$5}"' 2>/dev/null) || true
  k60_swap=$(ssh_device K60 'free|awk "/^Swap:/{if(\$2>0)printf \"%.0f%%\",(\$2-\$4)*100/\$2;else print \"—\"}"' 2>/dev/null) || k60_swap="—"
  k60_up=$(ssh_device K60 'uptime -p 2>/dev/null|sed "s/up //"' 2>/dev/null) || k60_up="—"

  # Note 7
  n7_gw=$(ssh_device Note7 'curl -s -o /dev/null -w "%{http_code}" --connect-timeout 3 http://127.0.0.1:18789/' 2>/dev/null) || n7_gw="fail"
  n7_mem=$(ssh_device Note7 'free -h | awk "/^Mem:/ {print \$7}"' 2>/dev/null) || n7_mem="—"
  n7_disk=$(ssh_device Note7 'df -h /data/data/com.termux/files 2>/dev/null|awk "NR==2{print \$3\"/\"\$2\" \"\$5}"' 2>/dev/null) || n7_disk="—"
  [ -z "$n7_disk" ] && n7_disk=$(ssh_device Note7 'df -h /data 2>/dev/null|awk "NR==2{print \$3\"/\"\$2\" \"\$5}"' 2>/dev/null) || true
  n7_swap=$(ssh_device Note7 'free|awk "/^Swap:/{if(\$2>0)printf \"%.0f%%\",(\$2-\$4)*100/\$2;else print \"—\"}"' 2>/dev/null) || n7_swap="—"
  n7_up=$(ssh_device Note7 'uptime -p 2>/dev/null|sed "s/up //"' 2>/dev/null) || n7_up="—"

  # Render cards
  local kgw_pill n7gw_pill
  [ "$k60_gw" = "200" ] && kgw_pill="$(pill_ok)" || kgw_pill="$(pill_off)"
  [ "$n7_gw" = "200" ] && n7gw_pill="$(pill_ok)" || n7gw_pill="$(pill_off)"

  printf "  ${C_DIM}${BOX_V}${C_RESET} ${C_BOLD}🔥 K60${C_RESET} — 随身主力机\n"
  printf "  ${C_DIM}${BOX_V}${C_RESET}   Gateway: %b  内存: ${C_GREEN}%s${C_RESET}  磁盘: %s  Swap: %s\n" \
    "$kgw_pill" "$k60_mem" "$k60_disk" "$k60_swap"
  printf "  ${C_DIM}${BOX_V}${C_RESET}   在线: %s\n" "$k60_up"
  echo -e "  ${C_DIM}${BOX_V}${C_RESET}"
  printf "  ${C_DIM}${BOX_V}${C_RESET} ${C_BOLD}🍃 Note 7${C_RESET} — 家里轻量机\n"
  printf "  ${C_DIM}${BOX_V}${C_RESET}   Gateway: %b  内存: ${C_GREEN}%s${C_RESET}  磁盘: %s  Swap: %s\n" \
    "$n7gw_pill" "$n7_mem" "$n7_disk" "$n7_swap"
  printf "  ${C_DIM}${BOX_V}${C_RESET}   在线: %s\n" "$n7_up"
  echo -e "  ${C_DIM}${BOX_V}${C_RESET}"
  printf "  ${C_DIM}${BOX_V}${C_RESET} ${C_DIM}⚡ MIX 2S · 🪨 Note 4X — 离线中${C_RESET}\n"
  echo -e "  ${C_DIM}${BOX_BL}$(printf "${BOX_H}%.0s" $(seq 1 56))${BOX_BR}${C_RESET}"

  echo
  echo -e "  ${C_BOLD}[r]${C_RESET} 刷新  ${C_BOLD}[R]${C_RESET} 强制刷新(清缓存)  ${C_BOLD}[0]${C_RESET} 返回"
  read -r -p "$(echo -e "  ${C_BOLD}>${C_RESET} ")" choice
  case "$choice" in
    r|R) dashboard_menu ;;
    *) show_menu ;;
  esac
}

# ═══ 5. Service ═══
service_menu() {
  clear
  header
  echo -e "  ${C_BOLD}${C_WHITE}⚙️ 服务管理${C_RESET}\n"
  menu_item "1" "📊" "本机状态"        "gateway HTTP + 进程信息"
  menu_item "2" "🔄" "本机重启"        "重启 gateway 服务"
  menu_item "3" "📋" "本机日志"        "实时跟踪 gateway 日志"
  menu_item "4" "🔥" "远程重启 K60"    "SSH 到 K60 重启 gateway"
  menu_item "5" "🍃" "远程重启 N7"     "SSH 到 Note 7 重启 gateway"
  echo -e "  ${C_BOLD}[0]${C_RESET} 返回"
  echo
  read -r -p "$(echo -e "  ${C_BOLD}>${C_RESET} ")" choice

  case "$choice" in
    1)
      local gw=$(check_gateway)
      printf "\n  Gateway: %s" "$gw"
      [ "$gw" = "200" ] && echo -e "  $(pill_ok)" || echo -e "  $(pill_off)"
      if is_termux; then
        ps aux 2>/dev/null | grep -E "[o]penclaw|[g]ateway" | while read -r l; do
          echo -e "  ${C_DIM}│${C_RESET} $l"
        done
      fi
      ;;
    2)
      confirm "确认重启本机 gateway？" || { show_menu; return; }
      log_step "重启中…"
      export SVDIR="$PREFIX/var/service"
      sv restart openclaw 2>/dev/null && log_ok "已重启" || log_fail "重启失败"
      sleep 3
      local gw=$(check_gateway)
      echo -e "  Gateway: $( [ "$gw" = "200" ] && pill_ok || pill_off )"
      ;;
    3) log_step "实时日志 (Ctrl+C 退出)"; tail -f "$PREFIX/var/log/sv/openclaw/current" 2>/dev/null || log_fail "日志不可用" ;;
    4)
      confirm "确认重启 K60 gateway？" || { show_menu; return; }
      ssh_device K60 'export SVDIR=$PREFIX/var/service && sv restart openclaw' && log_ok "K60 已重启" || log_fail "失败"
      ;;
    5)
      confirm "确认重启 Note 7 gateway？" || { show_menu; return; }
      ssh_device Note7 'export SVDIR=$PREFIX/var/service && sv restart openclaw' && log_ok "N7 已重启" || log_fail "失败"
      ;;
  esac
  press_enter; show_menu
}

# ═══ 6. Self-healing ═══
selfheal_menu() {
  clear
  header
  echo -e "  ${C_BOLD}${C_WHITE}🩺 自愈系统${C_RESET}\n"
  menu_item "1" "📦" "安装到本机"      "部署 healthcheck + self-check + crontab"
  menu_item "2" "📡" "安装到远程"      "SSH 部署到 K60 / Note 7"
  menu_item "3" "📊" "自愈状态"        "检查 crond / 脚本 / 重启记录"
  menu_item "4" "📋" "查看日志"        "互检日志 / 自检日志 / 告警记录"
  echo -e "  ${C_BOLD}[0]${C_RESET} 返回"
  echo
  read -r -p "$(echo -e "  ${C_BOLD}>${C_RESET} ")" choice

  case "$choice" in
    1) install_selfheal_local ;;
    2)
      echo; echo -e "  ${C_BOLD}目标:${C_RESET} [1] K60  [2] Note 7  [3] 两台"; read -r -p "  > " dc
      case "$dc" in
        1) install_selfheal_remote K60 k60-healthcheck.sh ;;
        2) install_selfheal_remote Note7 note7-healthcheck.sh ;;
        3) install_selfheal_remote K60 k60-healthcheck.sh; install_selfheal_remote Note7 note7-healthcheck.sh ;;
      esac
      ;;
    3) check_selfheal_status ;;
    4) view_selfheal_logs ;;
  esac
  press_enter; show_menu
}

install_selfheal_local() {
  log_step "安装自愈系统到本机…"
  cp "$SCRIPT_DIR/scripts/self-check.sh" ~/self-check.sh 2>/dev/null
  cp "$SCRIPT_DIR/scripts/k60-healthcheck.sh" ~/healthcheck.sh 2>/dev/null
  chmod +x ~/self-check.sh ~/healthcheck.sh 2>/dev/null
  (crontab -l 2>/dev/null || true
   echo "*/5 * * * * ~/healthcheck.sh"
   echo "*/10 * * * * ~/self-check.sh") | crontab - 2>/dev/null
  log_ok "已安装 — cron: */5 healthcheck + */10 self-check"
}

install_selfheal_remote() {
  local dev="$1" script="$2"
  log_step "安装到 $dev…"
  cat "$SCRIPT_DIR/scripts/$script" | ssh_device "$dev" 'cat > ~/healthcheck.sh && chmod +x ~/healthcheck.sh'
  cat "$SCRIPT_DIR/scripts/self-check.sh" | ssh_device "$dev" 'cat > ~/self-check.sh && chmod +x ~/self-check.sh'
  ssh_device "$dev" 'bash -c "(crontab -l 2>/dev/null || true; echo \"*/5 * * * * ~/healthcheck.sh\"; echo \"*/10 * * * * ~/self-check.sh\") | crontab -"'
  log_ok "$dev 已安装"
}

check_selfheal_status() {
  echo
  for dev in K60 Note7; do
    echo -e "  ${C_BOLD}── ${dev} ──${C_RESET}"
    if ssh_device "$dev" 'ps aux | grep -q "[c]rond -f"' 2>/dev/null; then
      echo -e "  crond:       $(pill_ok)"
    else
      echo -e "  crond:       $(pill_off)"
    fi
    ssh_device "$dev" '[ -x ~/healthcheck.sh ]' 2>/dev/null && echo -e "  healthcheck: $(pill_ok)" || echo -e "  healthcheck: $(pill_off)"
    ssh_device "$dev" '[ -x ~/self-check.sh ]' 2>/dev/null && echo -e "  self-check:  $(pill_ok)" || echo -e "  self-check:  $(pill_off)"
    local stamp; stamp=$(ssh_device "$dev" 'cat ~/healthcheck.last_restart 2>/dev/null' || echo "—")
    echo -e "  ${C_DIM}上次重启: $stamp${C_RESET}"
    ssh_device "$dev" 'crontab -l 2>/dev/null' | while read -r l; do echo -e "  ${C_DIM}cron: $l${C_RESET}"; done
  done
}

view_selfheal_logs() {
  echo; echo -e "  ${C_BOLD}日志类型:${C_RESET} [1] healthcheck  [2] self-check  [3] alert  [4] last_restart"; read -r -p "  > " lc
  echo -e "  ${C_BOLD}设备:${C_RESET} [1] K60  [2] Note 7"; read -r -p "  > " dc
  local dev; case "$dc" in 1) dev="K60" ;; 2) dev="Note7" ;; *) dev="K60" ;; esac
  echo
  case "$lc" in
    1) ssh_device "$dev" 'cat ~/healthcheck.log 2>/dev/null' || echo "  (无日志)" ;;
    2) ssh_device "$dev" 'cat ~/self-check.log 2>/dev/null' || echo "  (无日志)" ;;
    3) ssh_device "$dev" 'cat ~/self-check.alert.log 2>/dev/null' || echo "  (无告警 — 很好！)" ;;
    4) ssh_device "$dev" 'cat ~/healthcheck.last_restart 2>/dev/null && echo' || echo "  (无记录)" ;;
  esac
}

