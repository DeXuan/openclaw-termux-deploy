  echo -e "    skill/references/            ${C_DIM}— 技能参考手册${C_RESET}"
  echo

  press_enter
  show_menu
}

# ── CLI 模式 ──
if [ $# -gt 0 ]; then
  case "$1" in
    dashboard|dash|d)
      dashboard_menu
      exit 0
      ;;
    check|c)
      for dev in K60 Note7; do
        echo -e "\n${C_BOLD}─── $dev ───${C_RESET}"
        ssh_device "$dev" "sh -" < "$SCRIPT_DIR/scripts/phone_check_env.sh" 2>&1 || echo "  不可达"
      done
      exit 0
      ;;
    install|i)
      target="${2:-}"
      [ -z "$target" ] && { echo "用法: $0 install <K60|Note7|IP> [user]"; exit 1; }
      user="${3:-u0_a129}"
      cat "$SCRIPT_DIR/scripts/phone_install_openclaw.sh" | ssh -p 8022 "$user@$target" 'sh -'
      exit 0
      ;;
    *)
      echo "用法: $0 [dashboard|check|install <target>]"
      echo "  无参数 → 交互式 TUI"
      exit 1
      ;;
  esac
fi

