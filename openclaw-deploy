  case "$choice" in
    1)
      log_title "本机技能"
      openclaw skills list 2>/dev/null | head -80 || log_fail "openclaw 未运行"
      ;;
    2)
      read -r -p "  搜索关键词: " keyword
      [ -n "$keyword" ] && openclaw skills search "$keyword" 2>/dev/null
      echo
      read -r -p "  安装 (输入 slug 或留空跳过): " slug
      [ -n "$slug" ] && openclaw skills install "$slug" 2>/dev/null
      ;;
    3)
      echo
      echo -e "  ${C_BOLD}同步到:${C_RESET} [1] Note 7  [2] 全部在线设备"
      read -r -p "  > " sync_choice
      case "$sync_choice" in
        1)
          log_step "rsync → Note 7..."
          rsync -avz -e "ssh -p 8022" ~/.openclaw/workspace/skills/ u0_a171@100.91.94.44:~/.openclaw/workspace/skills/ 2>/dev/null && log_ok "同步完成" || log_fail "同步失败"
          ;;
        2)
          for dev in K60 Note7; do
            log_step "rsync → $dev..."
            local conn="${DEVICES[$dev]}"
            rsync -avz -e "ssh -p ${conn##*:}" ~/.openclaw/workspace/skills/ "${conn%:*}:~/.openclaw/workspace/skills/" 2>/dev/null && log_ok "$dev 完成" || log_fail "$dev 失败"
          done
          ;;
      esac
      ;;
    4)
      log_title "K60 技能统计"
      ssh_device K60 'openclaw skills list 2>/dev/null | head -15' || log_fail "K60 不可达"
      ;;
  esac
  press_enter
  show_menu
