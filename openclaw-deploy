#!/usr/bin/env bash
# openclaw-deploy — OpenClaw Termux 机队管理工具箱
# 用法: ./openclaw-deploy          (交互式 TUI)
#       ./openclaw-deploy check    (设备体检)
#       ./openclaw-deploy dashboard (机队仪表盘)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

# ── 菜单定义 ──
show_menu() {
  clear
  banner
  local device
  device=$(get_device_name 2>/dev/null || echo "PC")

  echo -e "  ${C_DIM}当前: ${C_BOLD}${device}${C_RESET}  ${C_DIM}|  $(date '+%H:%M')${C_RESET}"
  echo
  echo -e "  ${C_BOLD}[1]${C_RESET} 部署新设备         ${C_DIM}— 安装 Node.js / OpenClaw / runit${C_RESET}"
  echo -e "  ${C_BOLD}[2]${C_RESET} 设备体检           ${C_DIM}— 一键诊断机型/版本/服务状态${C_RESET}"
  echo -e "  ${C_BOLD}[3]${C_RESET} 服务管理           ${C_DIM}— 启停/重启/日志查看${C_RESET}"
  echo -e "  ${C_BOLD}[4]${C_RESET} 自愈系统           ${C_DIM}— 安装/配置/状态/日志${C_RESET}"
  echo -e "  ${C_BOLD}[5]${C_RESET} 机队仪表盘         ${C_DIM}— 四台设备状态一览${C_RESET}"
  echo -e "  ${C_BOLD}[6]${C_RESET} 技能工具箱         ${C_DIM}— 安装/同步/导出技能${C_RESET}"
  echo -e "  ${C_BOLD}[7]${C_RESET} 模型与渠道         ${C_DIM}— 模型供应商/渠道连接管理${C_RESET}"
  echo -e "  ${C_BOLD}[8]${C_RESET} 系统更新           ${C_DIM}— 升级 OpenClaw / Node.js${C_RESET}"
  echo
  echo -e "  ${C_BOLD}[h]${C_RESET} 帮助 & 快速命令    ${C_DIM}— 运维速查${C_RESET}"
  echo -e "  ${C_BOLD}[0]${C_RESET} 退出"
  echo

  read -r -p "$(echo -e "  ${C_BOLD}请选择${C_RESET} ${C_DIM}[0-8/h]${C_RESET}: ")" choice

  case "$choice" in
    1) deploy_menu ;;
    2) check_menu ;;
    3) service_menu ;;
    4) selfheal_menu ;;
    5) dashboard_menu ;;
    6) skills_menu ;;
    7) models_menu ;;
    8) update_menu ;;
    h|H) help_menu ;;
    0) echo -e "\n${C_DIM}再见 👋${C_RESET}\n"; exit 0 ;;
    *) show_menu ;;
  esac
}

# ── 1. 部署新设备 ──
deploy_menu() {
  clear
  banner
  echo -e "  ${C_BOLD}部署新设备${C_RESET}"
  echo
  echo -e "  ${C_DIM}支持两种模式：${C_RESET}"
  echo -e "    ${C_BOLD}[a]${C_RESET} PC 远程部署 ${C_DIM}— 通过 SSH 在目标手机上安装${C_RESET}"
  echo -e "    ${C_BOLD}[b]${C_RESET} 本机安装     ${C_DIM}— 在当前 Termux 手机上直接安装${C_RESET}"
  echo -e "    ${C_BOLD}[0]${C_RESET} 返回"
  echo

  read -r -p "$(echo -e "  ${C_BOLD}选择${C_RESET} ${C_DIM}[a/b/0]${C_RESET}: ")" choice

  case "$choice" in
    a|A)
      read -r -p "  目标设备 (K60/Note7/MIX2S/Note4X 或 IP): " target
      read -r -p "  SSH 用户: " ssh_user
      log_title "远程部署 → $target"
      if [ -f "$SCRIPT_DIR/scripts/phone_install_openclaw.sh" ]; then
        cat "$SCRIPT_DIR/scripts/phone_install_openclaw.sh" | ssh -p 8022 "$ssh_user@$target" 'sh -'
      else
        log_fail "找不到 scripts/phone_install_openclaw.sh"
      fi
      ;;
    b|B)
      log_title "本机安装"
      if [ -f "$SCRIPT_DIR/scripts/phone_install_openclaw.sh" ]; then
        bash "$SCRIPT_DIR/scripts/phone_install_openclaw.sh"
      else
        log_fail "找不到安装脚本"
      fi
      ;;
  esac
  press_enter
  show_menu
}

# ── 2. 设备体检 ──
check_menu() {
  clear
  banner
  echo -e "  ${C_BOLD}设备体检${C_RESET}"
  echo
  echo -e "  ${C_BOLD}[1]${C_RESET} 本机快速体检"
  echo -e "  ${C_BOLD}[2]${C_RESET} K60 远程体检"
  echo -e "  ${C_BOLD}[3]${C_RESET} Note 7 远程体检"
  echo -e "  ${C_BOLD}[4]${C_RESET} 全队一键体检"
  echo -e "  ${C_BOLD}[0]${C_RESET} 返回"
  echo

  read -r -p "$(echo -e "  ${C_BOLD}选择${C_RESET} ${C_DIM}[0-4]${C_RESET}: ")" choice

  case "$choice" in
    1)
      log_title "本机体检"
      if [ -f "$SCRIPT_DIR/scripts/phone_check_env.sh" ]; then
        bash "$SCRIPT_DIR/scripts/phone_check_env.sh"
      fi
      ;;
    2)
      log_title "K60 远程体检"
      ssh_device K60 "sh -" < "$SCRIPT_DIR/scripts/phone_check_env.sh" 2>&1 || log_fail "K60 不可达"
      ;;
    3)
      log_title "Note 7 远程体检"
      ssh_device Note7 "sh -" < "$SCRIPT_DIR/scripts/phone_check_env.sh" 2>&1 || log_fail "Note 7 不可达"
      ;;
    4)
      log_title "全队体检"
      for dev in K60 Note7; do
        echo -e "\n${C_BOLD}─── $dev ───${C_RESET}"
        ssh_device "$dev" "sh -" < "$SCRIPT_DIR/scripts/phone_check_env.sh" 2>&1 || echo "  ${ICON_FAIL} 不可达"
      done
      ;;
  esac
  press_enter
  show_menu
}

# ── 3. 服务管理 ──
service_menu() {
  clear
  banner
  echo -e "  ${C_BOLD}服务管理${C_RESET}"
  echo
  echo -e "  ${C_BOLD}[1]${C_RESET} 本机 gateway 状态"
  echo -e "  ${C_BOLD}[2]${C_RESET} 本机 gateway 重启"
  echo -e "  ${C_BOLD}[3]${C_RESET} 本机 gateway 日志 (实时)"
  echo -e "  ${C_BOLD}[4]${C_RESET} 远程 K60 gateway 重启"
  echo -e "  ${C_BOLD}[5]${C_RESET} 远程 Note 7 gateway 重启"
  echo -e "  ${C_BOLD}[0]${C_RESET} 返回"
  echo

  read -r -p "$(echo -e "  ${C_BOLD}选择${C_RESET} ${C_DIM}[0-5]${C_RESET}: ")" choice

  case "$choice" in
    1)
      local=http://127.0.0.1:18789/
      HTTP=$(check_gateway "$local")
      echo -e "\n  Gateway: $(status_badge "$HTTP")"
      ;;
    2)
      confirm "确认重启本机 gateway？" || { show_menu; return; }
      log_step "重启 gateway..."
      export SVDIR="$PREFIX/var/service"
      sv restart openclaw 2>/dev/null && log_ok "已重启" || log_fail "重启失败"
      sleep 3
      HTTP=$(check_gateway)
      echo "  Gateway: $(status_badge "$HTTP")"
      ;;
    3)
      log_title "gateway 实时日志 (Ctrl+C 退出)"
      tail -f "$PREFIX/var/log/sv/openclaw/current" 2>/dev/null || log_fail "日志文件不存在"
      ;;
    4)
      confirm "确认重启 K60 gateway？" || { show_menu; return; }
      log_step "SSH K60 重启 gateway..."
      ssh_device K60 'export SVDIR=$PREFIX/var/service && sv restart openclaw' && log_ok "已重启" || log_fail "重启失败"
      ;;
    5)
      confirm "确认重启 Note 7 gateway？" || { show_menu; return; }
      log_step "SSH Note 7 重启 gateway..."
      ssh_device Note7 'export SVDIR=$PREFIX/var/service && sv restart openclaw' && log_ok "已重启" || log_fail "重启失败"
      ;;
  esac
  press_enter
  show_menu
}

# ── 4. 自愈系统 ──
selfheal_menu() {
  clear
  banner
  echo -e "  ${C_BOLD}自愈系统${C_RESET}"
  echo
  echo -e "  ${C_BOLD}[1]${C_RESET} 安装到本机     ${C_DIM}— 部署 healthcheck + self-check + crontab${C_RESET}"
  echo -e "  ${C_BOLD}[2]${C_RESET} 安装到远程设备 ${C_DIM}— SSH 部署到 K60 / Note 7${C_RESET}"
  echo -e "  ${C_BOLD}[3]${C_RESET} 查看自愈状态   ${C_DIM}— 检查 crond + 脚本 + 最近日志${C_RESET}"
  echo -e "  ${C_BOLD}[4]${C_RESET} 查看自愈日志   ${C_DIM}— 互检日志 / 自检日志 / 告警日志${C_RESET}"
  echo -e "  ${C_BOLD}[0]${C_RESET} 返回"
  echo

  read -r -p "$(echo -e "  ${C_BOLD}选择${C_RESET} ${C_DIM}[0-4]${C_RESET}: ")" choice

  case "$choice" in
    1)
      install_selfheal_local
      ;;
    2)
      echo
      echo -e "  ${C_BOLD}选择目标设备:${C_RESET}"
      echo -e "  [1] K60  [2] Note 7  [3] 两台都装"
      read -r -p "  > " dev_choice
      case "$dev_choice" in
        1) install_selfheal_remote K60 k60-healthcheck.sh ;;
        2) install_selfheal_remote Note7 note7-healthcheck.sh ;;
        3)
          install_selfheal_remote K60 k60-healthcheck.sh
          install_selfheal_remote Note7 note7-healthcheck.sh
          ;;
      esac
      ;;
    3)
      check_selfheal_status
      ;;
    4)
      echo
      echo -e "  ${C_BOLD}选择日志:${C_RESET}"
      echo -e "  [1] healthcheck.log  [2] self-check.log  [3] alert.log  [4] last_restart"
      read -r -p "  > " log_choice
      local dev=${SELFHEAL_DEV:-}
      [ -z "$dev" ] && { echo -e "  设备 (K60/Note7): "; read -r dev; }
      case "$log_choice" in
        1) ssh_device "$dev" 'cat ~/healthcheck.log 2>/dev/null || echo "(无日志)"' ;;
        2) ssh_device "$dev" 'cat ~/self-check.log 2>/dev/null || echo "(无日志)"' ;;
        3) ssh_device "$dev" 'cat ~/self-check.alert.log 2>/dev/null || echo "(无告警)"' ;;
        4) ssh_device "$dev" 'cat ~/healthcheck.last_restart 2>/dev/null && echo || echo "(无记录)"' ;;
      esac
      ;;
  esac
  press_enter
  show_menu
}

install_selfheal_local() {
  log_title "安装自愈系统到本机"
  cp "$SCRIPT_DIR/scripts/self-check.sh" ~/self-check.sh 2>/dev/null
  cp "$SCRIPT_DIR/scripts/k60-healthcheck.sh" ~/healthcheck.sh 2>/dev/null
  chmod +x ~/self-check.sh ~/healthcheck.sh 2>/dev/null
  # crontab
  (crontab -l 2>/dev/null || true; echo "*/5 * * * * ~/healthcheck.sh"; echo "*/10 * * * * ~/self-check.sh") | crontab - 2>/dev/null
  log_ok "自愈系统已安装"
  log_info "crontab: */5 healthcheck + */10 self-check"
}

install_selfheal_remote() {
  local dev="$1" script="$2"
  log_title "安装自愈系统 → $dev"
  cat "$SCRIPT_DIR/scripts/$script" | ssh_device "$dev" 'cat > ~/healthcheck.sh && chmod +x ~/healthcheck.sh'
  cat "$SCRIPT_DIR/scripts/self-check.sh" | ssh_device "$dev" 'cat > ~/self-check.sh && chmod +x ~/self-check.sh'
  # Update crontab
  ssh_device "$dev" 'bash -c "(crontab -l 2>/dev/null || true; echo \"*/5 * * * * ~/healthcheck.sh\"; echo \"*/10 * * * * ~/self-check.sh\") | crontab -"'
  log_ok "$dev 自愈系统已安装"
}

check_selfheal_status() {
  log_title "自愈系统状态"
  for dev in K60 Note7; do
    echo -e "\n${C_BOLD}─── $dev ───${C_RESET}"
    # crond
    if ssh_device "$dev" 'ps aux | grep -q "[c]rond -f"' 2>/dev/null; then
      echo "  crond:   $(status_badge 200)"
    else
      echo "  crond:   $(status_badge fail)"
    fi
    # scripts
    if ssh_device "$dev" '[ -x ~/healthcheck.sh ] && echo ok' 2>/dev/null | grep -q ok; then
      echo "  healthcheck: $(status_badge 200)"
    else
      echo "  healthcheck: $(status_badge fail)"
    fi
    if ssh_device "$dev" '[ -x ~/self-check.sh ] && echo ok' 2>/dev/null | grep -q ok; then
      echo "  self-check:  $(status_badge 200)"
    else
      echo "  self-check:  $(status_badge fail)"
    fi
    # last restart
    local stamp
    stamp=$(ssh_device "$dev" 'cat ~/healthcheck.last_restart 2>/dev/null' || echo "无记录")
    echo "  上次重启: ${stamp:-无记录}"
    # crontab
    ssh_device "$dev" 'crontab -l 2>/dev/null' | while read -r line; do
      echo "  cron: $line"
    done || true
  done
}

# ── 5. 机队仪表盘 ──
dashboard_menu() {
  clear
  banner
  echo -e "  ${C_BOLD}机队仪表盘${C_RESET}     $(date '+%Y-%m-%d %H:%M')"
  echo
  printf "  %-8s %-10s %-8s %-6s %-6s %-s\n" "设备" "Gateway" "内存" "磁盘" "Swap" "上线"
  echo "  ${C_DIM}────────────────────────────────────────────────────${C_RESET}"

  for dev in K60 Note7; do
    local gw="—" mem="—" disk="—" swap_pct="—" uptime_str="—"
    # Gateway
    gw_code=$(ssh_device "$dev" 'curl -s -o /dev/null -w "%{http_code}" --connect-timeout 3 http://127.0.0.1:18789/' 2>/dev/null) || gw_code="fail"
    if [ "$gw_code" = "200" ]; then gw="${C_GREEN}●${C_RESET} 在线"
    else gw="${C_RED}●${C_RESET} 离线"; fi
    # Memory
    mem_info=$(ssh_device "$dev" 'free -h | awk "/^Mem:/ {print \$7}"' 2>/dev/null) || mem_info="—"
    [ -n "$mem_info" ] && mem="$mem_info"
    # Disk
    disk_info=$(ssh_device "$dev" 'df -h /data 2>/dev/null | awk "NR==2 {print \$3\"/\"\$2\" \"\$5}"' 2>/dev/null) || disk_info="—"
    [ -n "$disk_info" ] && disk="$disk_info"
    # Swap
    swap_info=$(ssh_device "$dev" 'free | awk "/^Swap:/ {if(\$2>0) printf \"%.0f%%\", (\$2-\$4)*100/\$2; else print \"—\"}"' 2>/dev/null) || swap_info="—"
    [ -n "$swap_info" ] && swap_pct="$swap_info"
    # Uptime
    uptime_info=$(ssh_device "$dev" 'uptime -p 2>/dev/null | sed "s/up //"' 2>/dev/null) || uptime_info="—"
    [ -n "$uptime_info" ] && uptime_str="$uptime_info"

    printf "  ${C_BOLD}%-8s${C_RESET} %-10b %-8s %-6s %-6s %-s\n" \
      "$dev" "$gw" "${mem:-—}" "${disk:-—}" "${swap_pct:-—}" "${uptime_str:-—}"
  done

  echo
  echo -e "  ${C_DIM}MIX 2S / Note 4X 离线中${C_RESET}"
  echo
  echo -e "  ${C_BOLD}[r]${C_RESET} 刷新  ${C_BOLD}[0]${C_RESET} 返回"
  read -r -p "$(echo -e "  ${C_BOLD}>${C_RESET} ")" choice
  case "$choice" in
    r|R) dashboard_menu ;;
    *) show_menu ;;
  esac
}

# ── 6. 技能工具箱 ──
skills_menu() {
  clear
  banner
  echo -e "  ${C_BOLD}技能工具箱${C_RESET}"
  echo
  echo -e "  ${C_BOLD}[1]${C_RESET} 本机技能列表     ${C_DIM}— 查看已安装技能${C_RESET}"
  echo -e "  ${C_BOLD}[2]${C_RESET} 搜索/安装技能    ${C_DIM}— ClawHub 搜索安装${C_RESET}"
  echo -e "  ${C_BOLD}[3]${C_RESET} 同步到远程设备   ${C_DIM}— rsync workspace skills${C_RESET}"
